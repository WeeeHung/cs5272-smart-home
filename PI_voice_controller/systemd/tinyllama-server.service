[Unit]
Description=TinyLlama persistent server (llama.cpp)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=cs5272smarthome
WorkingDirectory=/home/cs5272smarthome/smarthome/cs5272-smart-home
ExecStart=/home/cs5272smarthome/smarthome/cs5272-smart-home/llama.cpp/build/bin/llama-server -m /home/cs5272smarthome/smarthome/cs5272-smart-home/models/tinyllama-1.1b-chat-v1.0-q4_k_m.gguf -ngl 0 -c 1024 --host 127.0.0.1 --port 8081
Restart=always
RestartSec=2

[Install]
WantedBy=multi-user.target
